# Optional interface
# Default: open (local server IPMI device)
# IPMI_INTERFACE=open

# Optional IPMI command overrides (space-separated command arguments after `ipmitool`)
# Defaults are tuned for common Supermicro raw commands.
# IPMI_SET_MANUAL_COMMAND=raw 0x30 0x30 0x01 0x00
# IPMI_SET_AUTO_COMMAND=raw 0x30 0x30 0x01 0x01
# IPMI_SET_FAN_SPEED_TEMPLATE=raw 0x30 0x30 0x02 0xff {{HEX_SPEED}}
# IPMI_SENSOR_COMMAND=sdr type temperature

# Monitor timing (ms)
POLL_INTERVAL_MS=30000

# Safety thresholds (°C)
MAX_CPU_TEMP_C=85
RECOVERY_CPU_TEMP_C=60

# Sensor matching regex (case-insensitive)
# CPU default matches names like "CPU1 Temp" and exact "Temp"
CPU_SENSOR_REGEX=(^temp$|cpu)
# System default matches inlet/exhaust/ambient/system labels
SYSTEM_SENSOR_REGEX=(system|sys|inlet|ambient|exhaust)

# Temperature presets in format threshold:speed,threshold:speed
# Rule: highest threshold <= current reference temperature is used.
# Example behavior:
#  - below 50°C => 10%
#  - >= 51°C => 15%
FAN_PRESETS=0:10,51:15,60:25,70:40,75:60,80:80,85:100

# Whether to set fan mode back to auto on shutdown
RESTORE_AUTO_ON_EXIT=true

# Optional HTTP API for external control
API_ENABLED=false
API_HOST=127.0.0.1
API_PORT=7001
# Required when API_ENABLED=true (send as Authorization: Bearer <token>)
API_AUTH_TOKEN=change-me
